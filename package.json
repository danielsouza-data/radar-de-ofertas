{
  "name": "radar-de-ofertas",
  "version": "1.0.0",
  "description": "Agregador inteligente de ofertas com envio automatizado via WhatsApp",
  "main": "disparo-completo.js",
  "scripts": {
    "start": "node disparo-completo.js",
    "dev": "nodemon disparo-completo.js",
    "test": "node --test src/**/*.test.js",
    "security:audit": "node scripts/security-audit.js",
    "send:prod": "node disparo-completo.js",
    "send:scheduled": "node agendador-envios.js",
    "send:test:1": "powershell -NoProfile -Command \"$env:OFFER_LIMIT='1'; node disparo-completo.js\"",
    "dashboard": "node bin/dashboard-server.js",
    "control:plane": "node bin/control-plane-server.js"
  },
  "keywords": [
    "shopee",
    "mercado-livre",
    "whatsapp",
    "ofertas",
    "afiliado"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^8.0.4",
    "playwright": "^1.58.2",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
