# =============================================================================
# RADAR DE OFERTAS - TEMPLATE DE CONFIGURACAO
# =============================================================================
# Copie este arquivo para .env e preencha os valores reais:
#   copy .env.example .env
#
# NUNCA suba o .env para repositorio. Ele ja esta no .gitignore.
# Este arquivo (.env.example) nao contem valores sensiveis e pode ser commitado.
# =============================================================================

# -----------------------------------------------------------------------------
# Shopee Affiliate API
# Obter em: https://open.shopee.com/
# -----------------------------------------------------------------------------
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=

# -----------------------------------------------------------------------------
# Mercado Livre API
# Obter em: https://developers.mercadolivre.com.br/
# -----------------------------------------------------------------------------
MERCADO_LIVRE_CLIENT_ID=
MERCADO_LIVRE_CLIENT_SECRET=
MERCADO_LIVRE_ACCESS_TOKEN=
MERCADO_LIVRE_USER_ID=
MERCADO_LIVRE_AFFILIATE_USERNAME=
MERCADO_LIVRE_TOOL_ID=

# -----------------------------------------------------------------------------
# Amazon Associates API (futuramente)
# -----------------------------------------------------------------------------
# AMAZON_ACCESS_KEY=
# AMAZON_SECRET_KEY=
# AMAZON_ASSOCIATE_ID=
# AMAZON_REGION=BR

# -----------------------------------------------------------------------------
# WhatsApp Web
# WHATSAPP_CHANNEL_ID: ID do grupo/canal destino. Ex: 1234567890@g.us
# WHATSAPP_PHONE_NUMBER: Numero do remetente com DDI. Ex: 5511999999999
# -----------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER=
WHATSAPP_CHANNEL_NAME=
WHATSAPP_CHANNEL_ID=
WHATSAPP_METHOD=web

# -----------------------------------------------------------------------------
# Comportamento operacional
# OFFER_LIMIT: 0 = sem limite. Qualquer numero > 0 limita ofertas no ciclo
# INTERVALO_MS: milissegundos entre envios (padrao 300000 = 5 min)
# MAX_REPROCESS_POR_OFERTA: tentativas de reprocessamento em falha (padrao 1)
# SEND_LOCK_STALE_MS: ms para lock ser considerado obsoleto (padrao 7200000 = 2h)
# -----------------------------------------------------------------------------
OFFERS_PER_DAY=5
SEND_TIME=09:00
OFFER_LIMIT=0
INTERVALO_MS=300000
MAX_REPROCESS_POR_OFERTA=1
SEND_LOCK_STALE_MS=7200000

# -----------------------------------------------------------------------------
# Agendador
# SCHED_TZ: timezone para o cron (padrao America/Sao_Paulo)
# SCHEDULE_OVERRIDE_DATE: aplica janela especial SOMENTE na data informada (YYYY-MM-DD)
# SCHEDULE_OVERRIDE_START_HOUR / END_HOUR: horario inicial/final da janela especial
# -----------------------------------------------------------------------------
SCHED_TZ=America/Sao_Paulo
SCHEDULE_START_HOUR=9
SCHEDULE_END_HOUR=17
SCHEDULE_OVERRIDE_DATE=
SCHEDULE_OVERRIDE_START_HOUR=8
SCHEDULE_OVERRIDE_END_HOUR=17
SCHEDULER_STATUS_HEARTBEAT_MS=60000

# -----------------------------------------------------------------------------
# Dashboard
# DASHBOARD_PORT: porta do servidor web (padrao 3000)
# -----------------------------------------------------------------------------
DASHBOARD_PORT=3000
RADAR_PUBLIC_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Sessao WhatsApp / seguranca
# WHATSAPP_SESSION_PERMISSIONS_STRICT=true bloqueia startup se ACL/permissoes forem inseguras
# -----------------------------------------------------------------------------
WHATSAPP_SESSION_PERMISSIONS_STRICT=false
WHATSAPP_READY_HEARTBEAT_MS=60000

# -----------------------------------------------------------------------------
# Observabilidade e debug
# DEBUG_SHOPEE_AUTH=true somente para diagnostico local (nao usar em producao)
# MORNING_OPENING_ENABLED: envia mensagem de abertura antes do primeiro envio do dia
# OFFERS_CTA_EVENT_DATE: data do CTA em formato YYYY-MM-DD (ex.: 2026-04-04)
# -----------------------------------------------------------------------------
DEBUG_SHOPEE_AUTH=false
MORNING_OPENING_ENABLED=true
OFFERS_CTA_EVENT_DATE=2026-04-04

# -----------------------------------------------------------------------------
# Ambiente
# ENVIRONMENT: development | production
# -----------------------------------------------------------------------------
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Mercado Livre Link Builder
# REQUIRE_SHORT=false permite usar pool com links completos (nao apenas meli.la)
# STRICT_MATCH=false permite fallback para link do proprio item quando nao houver mapa
# -----------------------------------------------------------------------------
MERCADO_LIVRE_LINKBUILDER_REQUIRE_SHORT=false
MERCADO_LIVRE_LINKBUILDER_STRICT_MATCH=false
